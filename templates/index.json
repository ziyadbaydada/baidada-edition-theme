      "block_order": ["item1", "item2", "item3", "item4", "item5", "item6", "item7", "item8"],
      "settings": {
        "color_scheme": "scheme-1",
        "movement_direction": "left",
        "padding-block-start": 20,
        "padding-block-end": 20
