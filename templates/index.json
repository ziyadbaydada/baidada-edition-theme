{
  "sections": {
    "hero": {
      "type": "hero",
      "blocks": {
        "eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>Baidada Édition — Première publication</p>",
            "type_preset": "body",
            "font_size": "0.75rem",
            "letter_spacing": "0.2em",
            "case": "uppercase",
            "color": "var(--color-foreground)",
            "width": "fit-content"
          }
        },
        "title": {
          "type": "text",
          "settings": {
            "text": "<p>Avant la chute…<br><em>L'intelligence préventive</em></p>",
            "type_preset": "h1",
            "color": "var(--color-foreground-heading)",
            "width": "fit-content",
            "max_width": "large"
          }
        },
        "subtitle": {
          "type": "text",
          "settings": {
            "text": "<p>Et si la vraie force n'était pas de résister à la chute… mais de la voir venir ?</p>",
            "type_preset": "body",
            "font_size": "1.2rem",
            "color": "var(--color-foreground)",
            "width": "fit-content",
            "max_width": "medium"
          }
        },
        "cta_decouvrir": {
          "type": "button",
          "settings": {
            "label": "Découvrir le livre",
            "link": "/pages/le-livre",
            "style_class": "button-primary",
            "width": "fit-content"
          }
        },
        "cta_commander": {
          "type": "button",
          "settings": {
            "label": "Commander",
            "link": "/pages/acheter",
            "style_class": "button-secondary",
            "width": "fit-content"
          }
        }
      },
      "block_order": ["eyebrow", "title", "subtitle", "cta_decouvrir", "cta_commander"],
      "settings": {
        "color_scheme": "scheme-5",
        "layout_desktop": "overlap",
        "content_position_desktop": "left",
        "content_alignment_desktop": "left",
        "min_height_desktop": 90,
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
    "marquee": {
      "type": "marquee",
      "blocks": {
        "item1": { "type": "text", "settings": { "text": "Psychologie" } },
        "item2": { "type": "text", "settings": { "text": "Réflexion" } },
        "item3": { "type": "text", "settings": { "text": "Prévention" } },
        "item4": { "type": "text", "settings": { "text": "Intelligence" } },
        "item5": { "type": "text", "settings": { "text": "Équilibre" } },
        "item6": { "type": "text", "settings": { "text": "Savoir" } },
        "item7": { "type": "text", "settings": { "text": "Anticipation" } },
        "item8": { "type": "text", "settings": { "text": "Résilience" } }
