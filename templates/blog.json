{
  "sections": {
    "hero_blog": {
      "type": "hero",
      "blocks": {
        "eyebrow": {
          "type": "text",
          "settings": {
            "text": "<p>Baidada Édition</p>",
            "type_preset": "body",
            "font_size": "0.75rem",
            "letter_spacing": "0.2em",
            "case": "uppercase",
            "alignment": "center",
            "color": "var(--color-foreground)"
          }
        },
        "titre": {
          "type": "text",
          "settings": {
            "text": "<h1>Réflexions &amp; Intelligence</h1>",
            "type_preset": "h1",
            "alignment": "center",
            "color": "var(--color-foreground-heading)"
          }
        },
        "sous_titre": {
          "type": "text",
          "settings": {
            "text": "<p>Psychologie, prévention, développement de soi — pour ceux qui veulent voir avant la chute.</p>",
            "type_preset": "body",
            "font_size": "1.1rem",
            "alignment": "center",
            "color": "var(--color-foreground)"
          }
        }
      },
      "block_order": ["eyebrow", "titre", "sous_titre"],
      "settings": {
        "color_scheme": "scheme-5",
        "content_position_desktop": "center",
        "content_alignment_desktop": "center",
        "min_height_desktop": 40,
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
    "marquee_categories": {
