        "c2": { "type": "text", "settings": { "text": "Réflexions" } },
        "c3": { "type": "text", "settings": { "text": "Maximes" } },
        "c4": { "type": "text", "settings": { "text": "Développement personnel" } },
        "c5": { "type": "text", "settings": { "text": "Avant la Chute" } },
        "c6": { "type": "text", "settings": { "text": "Intelligence préventive" } }
