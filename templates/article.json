{
  "sections": {
    "section": {
      "type": "main-blog-post",
      "blocks": {
        "blog-post-title": {
          "type": "text",
          "name": "Title",
          "static": true,
          "settings": {
            "text": "<h1>{{ article.title }}</h1>",
            "width": "100%",
            "max_width": "normal",
            "alignment": "center",
            "type_preset": "h2",
            "font": "var(--font-primary--family)",
            "font_size": "",
            "line_height": "normal",
            "letter_spacing": "normal",
            "case": "none",
            "wrap": "pretty",
            "color": "",
            "background": false,
            "background_color": "#00000026",
            "corner_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "blog-post-details": {
          "type": "_blog-post-info-text",
          "name": "Details",
          "static": true,
          "settings": {
            "show_date": true,
            "show_author": true,
            "type_preset": "",
            "alignment": "center",
            "show_alignment": true,
            "padding-block-start": 24,
            "padding-block-end": 0
          },
          "blocks": {}
        },
        "blog-post-image": {
          "type": "image",
          "name": "Featured image",
          "static": true,
          "settings": {
            "image_ratio": "landscape",
            "width": "fill",
            "custom_width": 100,
            "width_mobile": "fill",
            "custom_width_mobile": 100,
            "height": "fit",
            "border": "none",
            "border_width": 1,
            "border_opacity": 100,
            "border_radius": 0,
            "padding-block-start": 0,
            "padding-block-end": 0,
            "padding-inline-start": 0,
            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "blog-post-content": {
          "type": "_blog-post-content",
          "static": true,
          "settings": {},
          "blocks": {}
        }
      },
      "settings": {
        "content_direction": "column",
        "gap": 32,
        "color_scheme": "scheme-1",
        "padding-block-start": 40,
        "padding-block-end": 80
      }
    },
    "citation_fin": {
      "type": "hero",
      "blocks": {
        "quote": {
          "type": "text",
          "settings": {
            "text": "<p>« Nourrir son esprit, c'est préparer son avenir. »</p>",
            "type_preset": "h3",
            "alignment": "center",
            "color": "var(--color-foreground-heading)"
          }
        },
        "attr": {
          "type": "text",
          "settings": {
            "text": "<p>— Baidada Édition</p>",
            "type_preset": "body",
            "letter_spacing": "0.2em",
            "case": "uppercase",
            "font_size": "0.75rem",
            "alignment": "center",
            "color": "var(--color-foreground)"
          }
        },
        "cta_livre": {
          "type": "button",
          "settings": {
            "label": "Découvrir le livre",
            "link": "/pages/le-livre",
            "style_class": "button-primary",
            "width": "fit-content"
          }
        }
      },
      "block_order": ["quote", "attr", "cta_livre"],
      "settings": {
        "color_scheme": "scheme-5",
        "content_position_desktop": "center",
        "content_alignment_desktop": "center",
        "min_height_desktop": 20,
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    },
    "articles_similaires": {
      "type": "featured-blog-posts",
      "blocks": {
        "titre_section": {
          "type": "_featured-blog-posts-title",
          "settings": {
            "heading": "Continuer la réflexion",
            "link": "/blogs/articles",
            "link_label": "Tous les articles"
          }
        },
        "card_1": { "type": "_featured-blog-posts-card", "settings": {} },
        "card_2": { "type": "_featured-blog-posts-card", "settings": {} },
        "card_3": { "type": "_featured-blog-posts-card", "settings": {} }
      },
      "block_order": ["titre_section", "card_1", "card_2", "card_3"],
      "settings": {
        "blog": "articles",
        "post_limit": 3,
        "color_scheme": "scheme-1",
        "section_width": "page-width",
        "padding-block-start": 80,
        "padding-block-end": 80
      }
    }
  },
  "order": [
    "section",
    "citation_fin",
    "articles_similaires"
  ]
}
